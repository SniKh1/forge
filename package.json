{
  "name": "forge-monorepo",
  "private": true,
  "version": "0.4.10",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "forge": "node packages/forge-cli/bin/forge.js",
    "forge:setup": "node packages/forge-cli/bin/forge.js setup",
    "forge:verify": "node packages/forge-cli/bin/forge.js verify",
    "forge:doctor": "node packages/forge-cli/bin/forge.js doctor",
    "forge:skills:sync": "node scripts/generate-skill-registry.js",
    "forge:session-memory": "node scripts/session-memory-report.js",
    "forge:mcp:sync": "node scripts/sync-mcp-to-global.js"
  }
}
