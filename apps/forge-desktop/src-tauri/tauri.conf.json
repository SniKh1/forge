{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "version": "0.4.2",
  "identifier": "com.forge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../../packages/forge-cli/**/*",
      "../../../scripts/**/*",
      "../../../codex/**/*",
      "../../../gemini/**/*",
      "../../../core/**/*",
      "../../../agents/**/*",
      "../../../commands/**/*",
      "../../../contexts/**/*",
      "../../../roles/**/*",
      "../../../rules/**/*",
      "../../../stacks/**/*",
      "../../../hooks/**/*",
      "../../../skills/**/*",
      "../../../CLAUDE.md",
      "../../../CAPABILITIES.md",
      "../../../USAGE-GUIDE.md",
      "../../../AGENTS.md",
      "../../../GUIDE.md",
      "../../../settings.json.template"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
