{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge Desktop",
  "version": "0.3.3",
  "identifier": "com.forge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge Desktop",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
